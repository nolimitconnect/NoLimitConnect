            ],
            "type": "process",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "linux-x64-release",
                "--target",
                "nolimitconnect"
            ],
            "problemMatcher": []
        },
        {
            "label": "Run Linux Debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Linux Debug"
            ],
            "type": "process",
            "command": "${workspaceFolder}/out/build/linux-x64-debug/nolimitgui/nolimitconnect",
            "problemMatcher": []
        },
        {
            "label": "Run Linux Release",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Linux Release"
            ],
            "type": "process",
            "command": "${workspaceFolder}/out/build/linux-x64-release/nolimitgui/nolimitconnect",
            "problemMatcher": []
        },
        {
            "label": "Build Linux",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Linux Debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "Run Linux",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Run Linux Debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "Windows: Prepare Debug Session",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Windows Debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "Android: Prepare Debug Session",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Deploy Android Debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "Linux: Prepare Debug Session",
            "dependsOrder": "sequence",
            "dependsOn": [
