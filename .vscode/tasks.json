        {
            "label": "Android: Force-stop app",
            "type": "process",
            "command": "powershell",
            "options": {
                "env": {
                    "ANDROID_SERIAL": "R5GL31TBG6N"
                }
            },
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$ErrorActionPreference='Continue'; $adb='F:/Android/Sdk/platform-tools/adb.exe'; if (-not (Test-Path $adb)) { Write-Host 'adb not found, skip force-stop.'; exit 0 }; $serial=$env:ANDROID_SERIAL; if (-not $serial) { $serial=((& $adb devices) | Select-Object -Skip 1 | Where-Object { $_ -match '^(\\S+)\\s+device$' } | ForEach-Object { if ($_ -match '^(\\S+)\\s+device$') { $Matches[1] } } | Select-Object -First 1) }; if (-not $serial) { Write-Host 'No Android device in state device; skip force-stop.'; exit 0 }; & $adb -s $serial shell am force-stop org.nolimitconnect.nolimitconnect 2>$null; Write-Host ('Force-stopped app on device: ' + $serial); exit 0"
            ],
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "ADB=/home/nolimit/Android/Sdk/platform-tools/adb; SERIAL=${ANDROID_SERIAL:-R5GL31TBG6N}; if [ ! -x \"$ADB\" ]; then echo 'adb not found, skip force-stop.'; exit 0; fi; $ADB -s \"$SERIAL\" shell am force-stop org.nolimitconnect.nolimitconnect 2>/dev/null; echo \"Force-stopped app on device: $SERIAL\"; exit 0"
                ]
            },
            "problemMatcher": []
        },
