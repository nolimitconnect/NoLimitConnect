{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Open current .ui in Qt Creator",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\open-ui-in-qtcreator.ps1",
                "-UiFile",
                "${file}"
            ],
            "problemMatcher": []
        },
        {
            "label": "Open Project in Qt Creator",
            "type": "shell",
            "command": "F:/Qt/Tools/QtCreator/bin/qtcreator.exe",
            "args": [
                "${workspaceFolder}"
            ],
            "problemMatcher": []
        },
        {
            "label": "Android: Start app + forward LLDB (5039)",
            "type": "process",
            "command": "powershell",
            "options": {
                "env": {
                    "ANDROID_SERIAL": "R8YW510D8KW"
                }
            },
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\android-start-forward-lldb.ps1",
                "-DebugSocketWaitSeconds",
                "15"
            ],
            "problemMatcher": []
        },
        {
            "label": "Configure Windows Debug",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\cmake-with-msvc-env.ps1",
                "--preset",
                "windows-debug",
                "--fresh"
            ],
            "problemMatcher": []
        },
        {
            "label": "Configure Windows Release",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\cmake-with-msvc-env.ps1",
                "--preset",
                "windows-release",
                "--fresh"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build Windows Debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Configure Windows Debug"
            ],
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\cmake-with-msvc-env.ps1",
                "--build",
                "--preset",
                "windows-debug",
                "--target",
                "nolimitconnect"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build Windows Release",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Configure Windows Release"
            ],
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\cmake-with-msvc-env.ps1",
                "--build",
                "--preset",
                "windows-release",
                "--target",
                "nolimitconnect"
            ],
            "problemMatcher": []
        },
        {
            "label": "Run Windows Debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Windows Debug"
            ],
            "type": "process",
            "command": "${workspaceFolder}/build/windows-debug/nolimitgui/nolimitconnect.exe",
            "options": {
                "env": {
                    "PATH": "F:/Qt/6.9.3/msvc2022_64/bin;${env:PATH}"
                }
            },
            "problemMatcher": []
        },
        {
            "label": "Run Windows Release",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Windows Release"
            ],
            "type": "process",
            "command": "${workspaceFolder}/build/windows-release/nolimitgui/nolimitconnect.exe",
            "options": {
                "env": {
                    "PATH": "F:/Qt/6.9.3/msvc2022_64/bin;${env:PATH}"
                }
            },
            "problemMatcher": []
        },
        {
            "label": "Build Windows",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Windows Debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "Run Windows",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Run Windows Debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "Configure Android Debug",
            "type": "process",
            "command": "cmake",
            "args": [
                "--preset",
                "android-arm64-debug",
                "--fresh"
            ],
            "problemMatcher": []
        },
        {
            "label": "Configure Android Release",
            "type": "process",
            "command": "cmake",
            "args": [
                "--preset",
                "android-arm64-release",
                "--fresh"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build Android Debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Configure Android Debug"
            ],
            "type": "process",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "android-arm64-debug",
                "--target",
                "nolimitconnect"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build Android Release",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Configure Android Release"
            ],
            "type": "process",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "android-arm64-release",
                "--target",
                "nolimitconnect"
            ],
            "problemMatcher": []
        },
        {
            "label": "Deploy Android Debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Android Debug",
                "Android: Start app + forward LLDB (5039)"
            ],
            "problemMatcher": []
        },
        {
            "label": "Deploy Android Release",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Android Release",
                "Android: Start app + forward LLDB (5039)"
            ],
            "problemMatcher": []
        },
        {
            "label": "Run Android Debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Deploy Android Debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "Run Android Release",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Deploy Android Release"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build Android",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Android Debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "Run Android",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Run Android Debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "Configure Linux Debug",
            "type": "process",
            "command": "cmake",
            "args": [
                "--preset",
                "linux-x64-debug",
                "--fresh"
            ],
            "problemMatcher": []
        },
        {
            "label": "Configure Linux Release",
            "type": "process",
            "command": "cmake",
            "args": [
                "--preset",
                "linux-x64-release",
                "--fresh"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build Linux Debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Configure Linux Debug"
            ],
            "type": "process",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "linux-x64-debug",
                "--target",
                "nolimitconnect"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build Linux Release",
            "dependsOrder": "sequence",
            "dependsOn": [
