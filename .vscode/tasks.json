{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Open current .ui in Qt Creator",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\open-ui-in-qtcreator.ps1",
                "-UiFile",
                "${file}"
            ],
            "problemMatcher": []
        },
        {
            "label": "Open Project in Qt Creator",
            "type": "shell",
            "command": "F:/Qt/Tools/QtCreator/bin/qtcreator.exe",
            "args": [
                "${workspaceFolder}"
            ],
            "problemMatcher": []
        },
        {
            "label": "Android: Start app + forward LLDB (5039)",
            "type": "process",
            "command": "powershell",
            "options": {
                "env": {
                    "ANDROID_SERIAL": "GN42DM044394023L"
                }
            },
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\android-start-forward-lldb.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "Android: Set CMake Tools presets (android-arm64-debug)",
            "type": "shell",
            "command": "echo",
            "args": [
                "Switched CMake presets to ${input:cmakeSetAndroidConfigurePreset} / ${input:cmakeSetAndroidBuildPreset}"
            ],
            "problemMatcher": []
        },
        {
            "label": "Android: CMake Configure (android-arm64-debug)",
            "type": "process",
            "command": "cmake",
            "args": [
                "--preset",
                "android-arm64-debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "Android: Prepare Debug Session",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Android: Set CMake Tools presets (android-arm64-debug)",
                "Android: CMake Configure (android-arm64-debug)",
                "Android: Start app + forward LLDB (5039)"
            ],
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "cmakeSetAndroidConfigurePreset",
            "type": "command",
            "command": "cmake.setConfigurePreset",
            "args": "android-arm64-debug"
        },
        {
            "id": "cmakeSetAndroidBuildPreset",
            "type": "command",
            "command": "cmake.setBuildPreset",
            "args": "android-arm64-debug"
        }
    ]
}
