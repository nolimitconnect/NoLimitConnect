        {
            "label": "Package Flatpak",
            "type": "process",
            "command": "bash",
            "args": [
                "-lc",
                "grep -q -- \"-DCMAKE_BUILD_TYPE=Release\" \"${workspaceFolder}/com.nolimitconnect.NoLimitConnect.yml\" || { echo \"Flatpak manifest must set -DCMAKE_BUILD_TYPE=Release\"; exit 1; }; mkdir -p \"${workspaceFolder}/build/flatpak-repo\" \"${workspaceFolder}/build/flatpak-build-release-dir\" \"${workspaceFolder}/package/flatpack\"; flatpak-builder --force-clean --repo=\"${workspaceFolder}/build/flatpak-repo\" \"${workspaceFolder}/build/flatpak-build-release-dir\" \"${workspaceFolder}/com.nolimitconnect.NoLimitConnect.yml\"; flatpak build-bundle \"${workspaceFolder}/build/flatpak-repo\" \"${workspaceFolder}/package/flatpack/nolimitconnect.flatpak\" com.nolimitconnect.NoLimitConnect"
