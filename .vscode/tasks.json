        {
            "label": "Install Android Debug APK (manual launch)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Package Android Debug"
            ],
            "type": "process",
            "command": "powershell",
            "linux": {
                "command": "bash",
                "args": [
                    "-lc",
                    "set -e; ADB=${ADB_PATH:-/home/nolimit/Android/Sdk/platform-tools/adb}; if [ ! -x \"$ADB\" ]; then echo \"adb not found: $ADB\"; exit 1; fi; PKG=org.nolimitconnect.nolimitconnect; mapfile -t DEVICES < <(\"$ADB\" devices | awk '$2==\"device\" {print $1}'); if [ ${#DEVICES[@]} -eq 0 ]; then echo \"No Android device in state device.\"; \"$ADB\" devices -l; exit 1; fi; SERIAL=${ANDROID_SERIAL:-}; if [ -n \"$SERIAL\" ]; then found=0; for d in \"${DEVICES[@]}\"; do if [ \"$d\" = \"$SERIAL\" ]; then found=1; break; fi; done; if [ \"$found\" -ne 1 ]; then echo \"Requested ANDROID_SERIAL '$SERIAL' is not connected. Using '${DEVICES[0]}' instead.\"; SERIAL=\"${DEVICES[0]}\"; fi; else SERIAL=\"${DEVICES[0]}\"; fi; roots=(\"${workspaceFolder}/package/android\" \"${workspaceFolder}/package/android/debug/arm64\" \"${workspaceFolder}/deploy/android\" \"${workspaceFolder}/build/android-arm64-debug/nolimitgui/android-build-nolimitconnect/build/outputs/apk/debug\" \"${workspaceFolder}/build/android-arm64-debug\"); apk=\"\"; for root in \"${roots[@]}\"; do if [ -d \"$root\" ]; then found=$(find \"$root\" -type f -name '*.apk' -printf '%T@ %p\\n' 2>/dev/null | sort -nr | head -n1 | cut -d' ' -f2- || true); if [ -n \"$found\" ]; then apk=\"$found\"; break; fi; fi; done; if [ -z \"$apk\" ]; then echo \"No APK found under: ${roots[*]}\"; exit 1; fi; echo \"Force-stopping app before install: $PKG\"; \"$ADB\" -s \"$SERIAL\" shell am force-stop \"$PKG\" 2>/dev/null || true; echo \"Installing APK: $apk\"; \"$ADB\" -s \"$SERIAL\" install -r \"$apk\"; echo \"Installed on device: $SERIAL\""
                ]
            },
            "options": {
                "env": {
                    "ANDROID_SERIAL": "R5GL31TBG6N"
                }
            },
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$ErrorActionPreference='Stop'; $adb='F:/Android/Sdk/platform-tools/adb.exe'; if (-not (Test-Path $adb)) { throw 'adb not found' }; $serial=$env:ANDROID_SERIAL; if (-not $serial) { $serial=((& $adb devices) | Select-Object -Skip 1 | Where-Object { $_ -match '^(\\S+)\\s+device$' } | ForEach-Object { if ($_ -match '^(\\S+)\\s+device$') { $Matches[1] } } | Select-Object -First 1) }; if (-not $serial) { throw 'No Android device in state device.' }; $pkg='org.nolimitconnect.nolimitconnect'; $roots=@('${workspaceFolder}/package/android','${workspaceFolder}/package/android/debug/arm64','${workspaceFolder}/deploy/android','${workspaceFolder}/build/android-arm64-debug/nolimitgui/android-build-nolimitconnect/build/outputs/apk/debug','${workspaceFolder}/build/android-arm64-debug'); $apk=$null; foreach($root in $roots){ if(Test-Path $root){ $apk=Get-ChildItem -Path $root -Recurse -Filter '*.apk' | Sort-Object LastWriteTime -Descending | Select-Object -First 1; if($apk){ break } } }; if (-not $apk) { throw ('No APK found under: ' + ($roots -join ', ')) }; Write-Host ('Force-stopping app before install: ' + $pkg); & $adb -s $serial shell am force-stop $pkg 2>$null; Write-Host ('Installing APK: ' + $apk.FullName); & $adb -s $serial install -r $apk.FullName; if ($LASTEXITCODE -ne 0) { throw ('adb install failed with exit code ' + $LASTEXITCODE) }; Write-Host ('Installed on device: ' + $serial)"
            ],
            "problemMatcher": []
        },
