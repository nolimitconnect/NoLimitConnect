{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Open current .ui in Qt Creator",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\open-ui-in-qtcreator.ps1",
                "-UiFile",
                "${file}"
            ],
            "problemMatcher": []
        },
        {
            "label": "Android: Start app + forward LLDB (5039)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "F:/Android/Sdk/platform-tools/adb.exe start-server; F:/Android/Sdk/platform-tools/adb.exe shell am start -n com.nolimitconnect.nolimitconnect/org.qtproject.qt.android.bindings.QtActivity; F:/Android/Sdk/platform-tools/adb.exe forward tcp:5039 tcp:5039"
            ],
            "problemMatcher": []
        }
    ]
}
