{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Open current .ui in Qt Creator",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\open-ui-in-qtcreator.ps1",
                "-UiFile",
                "${file}"
            ],
            "linux": {
                "command": "bash",
                "args": [
                    "${workspaceFolder}/.vscode/open-ui-in-qtcreator.sh",
                    "${file}"
                ]
            },
            "problemMatcher": []
        },
        {
            "label": "Open Project in Qt Creator",
            "type": "shell",
            "command": "F:/Qt/Tools/QtCreator/bin/qtcreator.exe",
            "args": [
                "${workspaceFolder}"
            ],
            "problemMatcher": []
        },
        {
            "label": "Extract TS Translations (lupdate)",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\cmake-with-msvc-env.ps1",
                "--build",
                "--preset",
                "windows-debug",
                "--target",
                "nolimitconnect_lupdate"
            ],
            "problemMatcher": []
        },
        {
            "label": "Full Translate TS",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/full-translate-ts.ps1",
                "-WorkspaceFolder",
                "${workspaceFolder}"
            ],
            "problemMatcher": []
        },
        {
            "label": "Compile TS to QM (lrelease)",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\cmake-with-msvc-env.ps1",
                "--build",
                "--preset",
                "windows-debug",
                "--target",
                "nolimitconnect_translations"
            ],
            "problemMatcher": []
        },
        {
            "label": "Run Translation Tasks",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Extract TS Translations (lupdate)",
                "Full Translate TS",
                "Compile TS to QM (lrelease)"
            ],
            "problemMatcher": []
        },
