{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Linux Debug nolimitconnect",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "Linux: Prepare Debug Session",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${command:cmake.launchTargetDirectory}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Windows Debug nolimitconnect",
            "type": "cppvsdbg",
            "request": "launch",
            "preLaunchTask": "Windows: Prepare Debug Session",
            "program": "${command:cmake.launchTargetPath}",
            "cwd": "${command:cmake.launchTargetDirectory}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "F:/Qt/6.9.3/msvc2022_64/bin;${env:PATH}"
                }
            ],
        },
        {
            "name": "Android Debug nolimitconnect (CodeLLDB)",
            "type": "lldb",
            "request": "custom",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Android: Prepare Debug Session",
            "targetCreateCommands": [
                "target create \"${input:androidSymbolFile}\""
            ],
            "processCreateCommands": [
                "platform select remote-android",
                "process connect connect://localhost:5039"
            ],
            "sourceMap": {
                "/proc/self/cwd": "${workspaceFolder}",
                "/": "${workspaceFolder}"
            }
        }
    ],
    "inputs": [
        {
            "id": "androidSymbolFile",
            "type": "promptString",
            "description": "Path to native symbol file (.so)",
            "default": "${workspaceFolder}/build/android-arm64-debug/nolimitgui/libnolimitconnect_arm64-v8a.so"
        }
    ]
}
